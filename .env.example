# Telegram bot token from @BotFather.
BOT_TOKEN=123456:replace_with_real_token

# Runtime mode: dev for local runs, prod for deployment.
APP_ENV=dev

# SQLite file path. Use :memory: only for short-lived local experiments/tests.
DATABASE_PATH=data/metaphor_card.db

# Optional path to bundled YAML content. Leave as-is for the repository defaults.
CONTENT_ROOT=content

# Logging verbosity. Invalid values fall back to INFO.
LOG_LEVEL=INFO
